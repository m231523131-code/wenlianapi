# Test server instance defaults. Copy to .env.test on the server and replace secrets.
TEST_BIND_HOST=0.0.0.0
TEST_SERVER_PORT=18080
RUN_MODE=standard
TZ=Asia/Shanghai

POSTGRES_USER=wenlianapi
POSTGRES_PASSWORD=replace_with_random_password
POSTGRES_DB=wenlianapi

REDIS_PASSWORD=
REDIS_DB=0

ADMIN_EMAIL=admin@wenlianapi.local
ADMIN_PASSWORD=replace_with_random_admin_password

JWT_SECRET=replace_with_random_32_byte_hex
TOTP_ENCRYPTION_KEY=replace_with_random_32_byte_hex
